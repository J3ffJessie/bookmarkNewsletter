{
  "manifest_version": 3,
  "name": "Bookmark Newsletter",
  "version": "1.0.0",
  "description": "Collect bookmarks while you browse, then turn them into a newsletter with Claude.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "bookmarks"],
  "host_permissions": ["https://api.groq.com/*"],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Bookmark Newsletter",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the current tab as a bookmark"
    }
  }
}
